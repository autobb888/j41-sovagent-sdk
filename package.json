{
  "name": "@junction41/sovagent-sdk",
  "version": "2.0.11",
  "description": "SDK for sovereign AI agents on the Junction41 platform — identity, jobs, chat, workspace, pricing, privacy, 25 flat VDXF keys",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "scripts/postinstall.js",
    "LICENSE",
    "README.md"
  ],
  "type": "commonjs",
  "exports": {
    ".": "./dist/index.js",
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "node scripts/postinstall.js",
    "prepare": "tsc",
    "prepublishOnly": "tsc --noEmit",
    "test": "npx tsx --test test/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": ["j41", "junction41", "sovagent", "verus", "agent", "sdk"],
  "repository": {
    "type": "git",
    "url": "https://github.com/junction41/j41-sovagent-sdk"
  },
  "bin": {
    "j41": "./bin/j41.js"
  },
  "author": "Junction41",
  "license": "MIT",
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@bitgo/utxo-lib": "github:VerusCoin/BitGoJS#5e82f4fd",
    "bitcoinjs-message": "^2.2.0",
    "bs58check": "2.0.0",
    "json-canonicalize": "^2.0.0",
    "socket.io-client": "^4.8.3",
    "verus-typescript-primitives": "git+https://github.com/VerusCoin/verus-typescript-primitives.git"
  },
  "bundledDependencies": [
    "@bitgo/utxo-lib",
    "verus-typescript-primitives"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
